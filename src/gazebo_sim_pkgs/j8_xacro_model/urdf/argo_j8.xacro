<!-- Fixposition holder
<xacro:bridge_joint xyz="-0.0028148 -0.11697 0.21171" rpy="1.5708 0 1.5708"/>-->
<!-- Fixposition sensor-->
  <xacro:fixposition_full_setup parent="Bridge" xyz="-0.0028148 -0.11697 0.21171" rpy="1.5708 0 1.5708"/>
  
 <gazebo>
  <!-- Diff drive plugin configuration -->
  <plugin name='diff_drive' filename='libgazebo_ros_j8_wheels_plugin.so'>
    <ros>
      <namespace>/ARGJ801</namespace>
      <remapping>odom:=odom_demo</remapping>
    </ros>
    <max_throttle_acceleration>1.86</max_throttle_acceleration>
    <max_steer_acceleration>1.23</max_steer_acceleration>
    <update_rate>200</update_rate>

    <!-- Wheels configuration -->
    <num_wheel_pairs>4</num_wheel_pairs>
    <left_joint>Suspension_1_Wheel_1_joint</left_joint>
    <left_joint>Suspension_2_Wheel_2_joint</left_joint>
    <left_joint>Suspension_3_Wheel_3_joint</left_joint>
    <left_joint>Suspension_4_Wheel_4_joint</left_joint>
    <right_joint>Suspension_5_Wheel_5_joint</right_joint>
    <right_joint>Suspension_6_Wheel_6_joint</right_joint>
    <right_joint>Suspension_7_Wheel_7_joint</right_joint>
    <right_joint>Suspension_8_Wheel_8_joint</right_joint>
    <!-- Kinematics -->
    <wheel_separation>1.26</wheel_separation>   <!-- repítelo 4 veces -->
    <wheel_separation>1.26</wheel_separation>
    <wheel_separation>1.26</wheel_separation>
    <wheel_separation>1.26</wheel_separation>

    <wheel_diameter>0.596</wheel_diameter>      <!-- idem -->
    <wheel_diameter>0.596</wheel_diameter>
    <wheel_diameter>0.596</wheel_diameter>
    <wheel_diameter>0.596</wheel_diameter>
    <!-- Limits -->
    <max_wheel_torque>100000000000</max_wheel_torque>
    <max_wheel_acceleration>100.0</max_wheel_acceleration>
    <!-- Output -->
    <publish_odom>true</publish_odom>
    <publish_odom_tf>true</publish_odom_tf>
    <publish_wheel_tf>true</publish_wheel_tf>
    <odometry_frame>odom</odometry_frame>
    <robot_base_frame>base_link</robot_base_frame>
  </plugin>
</gazebo>

 <gazebo reference="base_link">
    <sensor name="br_imu" type="imu">
        <always_on>true</always_on>
        <update_rate>100</update_rate>
        <imu>
          <angular_velocity>
            <x>
              <noise type="gaussian">
                <mean>0.01</mean>
                <stddev>0.001</stddev>
              </noise>
            </x>
            <y>
              <noise type="gaussian">
                <mean>0.01</mean>
                <stddev>0.001</stddev>
              </noise>
            </y>
            <z>
              <noise type="gaussian">
                <mean>0.01</mean>
                <stddev>0.001</stddev>
              </noise>
            </z>
          </angular_velocity>
          
          <linear_acceleration>
            <x>
              <noise type="gaussian">
                <mean>0.01</mean>
                <stddev>0.001</stddev>
              </noise>
            </x>
            <y>
              <noise type="gaussian">
                <mean>0.01</mean>
                <stddev>0.001</stddev>
              </noise>
            </y>
            <z>
              <noise type="gaussian">
                <mean>0.01</mean>
                <stddev>0.001</stddev>
              </noise>
            </z>
          </linear_acceleration>
          
        </imu>
        <plugin name="bytes_imu" filename="libgazebo_ros_imu_sensor.so">
            <ros>
                <namespace>/ARGJ801</namespace>
                <remapping>~/out:=data</remapping>
            </ros>
            <initial_orientation_as_reference>false</initial_orientation_as_reference>
        </plugin>
    </sensor>
</gazebo>



<gazebo>
  <plugin name="joint_state_publisher_plugin" filename="libjoints_plugin.so">
    <robotNamespace>argo</robotNamespace>
    <updateRate>50.0</updateRate>
  </plugin>
</gazebo>


</robot>

 
