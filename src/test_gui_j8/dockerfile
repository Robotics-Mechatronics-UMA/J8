# ROS 2 Humble + PySide6 (Qt WebEngine) + deps X11/GL
FROM ubuntu:22.04

ARG ROS_DISTRO=humble
ENV DEBIAN_FRONTEND=noninteractive \
    LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8

# ---- APT base + X11/GL + codecs + piezas que WebEngine exige ----
RUN apt-get update && apt-get install -y --no-install-recommends \
    locales curl gnupg lsb-release ca-certificates software-properties-common \
    build-essential python3-dev python3-pip python3-distutils \
    libnss3 libx11-6 libx11-xcb1 libxkbcommon0 libxkbcommon-x11-0 \
    libxcomposite1 libxdamage1 libxrandr2 libxrender1 libxfixes3 \
    libxcb1 libxcb-icccm4 libxcb-image0 libxcb-keysyms1 libxcb-render-util0 \
    libxcb-render0 libxcb-shm0 libxcb-shape0 libxcb-xinerama0 libxcb-xinput0 libxcb-cursor0 \
    libxss1 libxtst6 libxkbfile1 libxshmfence1 \
    libdrm2 libgbm1 libegl1 libgl1-mesa-dri libgl1-mesa-glx libglu1-mesa \
    libasound2 libatspi2.0-0 xdg-utils fonts-dejavu-core \
    gstreamer1.0-plugins-base gstreamer1.0-plugins-good gstreamer1.0-libav \
    libatomic1 \
 && locale-gen en_US.UTF-8 \
 && rm -rf /var/lib/apt/lists/*

# ---- Repos ROS 2 ----
RUN install -d /etc/apt/keyrings && \
    curl -sSL https://raw.githubusercontent.com/ros/rosdistro/master/ros.key \
    | gpg --dearmor -o /etc/apt/keyrings/ros2.gpg && \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/ros2.gpg] \
    http://packages.ros.org/ros2/ubuntu $(lsb_release -cs) main" \
    > /etc/apt/sources.list.d/ros2.list

# ---- ROS 2 base + colcon ----
RUN apt-get update && apt-get install -y --no-install-recommends \
    ros-${ROS_DISTRO}-ros-base \
    python3-colcon-common-extensions python3-vcstool \
 && rm -rf /var/lib/apt/lists/*

# ---- Python: PySide6 + Addons ----
RUN python3 -m pip install --no-cache-dir --upgrade pip setuptools wheel packaging && \
    python3 -m pip install --no-cache-dir "numpy<1.24" PySide6~=6.5 PySide6-Addons utm pyproj

# ---- Workspace ----
WORKDIR /ros2_ws

# MUY IMPORTANTE: no pongas barra inicial aquí:
# copia tu src/ al workspace; la estructura debe ser /ros2_ws/src/j8_gui/...
COPY src/ /ros2_ws/src/

# Vendor Leaflet si está el recurso (ajusta ruta si tu paquete se llama distinto)
RUN bash -lc 'set -eux; \
  RESDIR=/ros2_ws/src/j8_gui/j8_gui/resources; \
  if [ -d "$RESDIR" ]; then \
    mkdir -p "$RESDIR/vendor/leaflet/images"; \
    LVER=1.9.4; \
    wget -q https://unpkg.com/leaflet@${LVER}/dist/leaflet.js  -O "$RESDIR/vendor/leaflet/leaflet.js"; \
    wget -q https://unpkg.com/leaflet@${LVER}/dist/leaflet.css -O "$RESDIR/vendor/leaflet/leaflet.css"; \
    wget -q https://unpkg.com/leaflet@${LVER}/dist/images/marker-icon.png     -O "$RESDIR/vendor/leaflet/images/marker-icon.png"; \
    wget -q https://unpkg.com/leaflet@${LVER}/dist/images/marker-icon-2x.png  -O "$RESDIR/vendor/leaflet/images/marker-icon-2x.png"; \
    wget -q https://unpkg.com/leaflet@${LVER}/dist/images/marker-shadow.png   -O "$RESDIR/vendor/leaflet/images/marker-shadow.png"; \
  else \
    echo "WARNING: no j8_gui/j8_gui/resources; skipping Leaflet"; \
  fi'

# ---- Compilar ----
RUN bash -lc "set -e \
  && source /opt/ros/${ROS_DISTRO}/setup.bash \
  && colcon build --symlink-install"

# ---- Entrypoint que prepara entorno y runtime dir ----
RUN bash -lc 'printf "%s\n" \
  "#!/usr/bin/env bash" \
  "set -e" \
  "export QT_QPA_PLATFORM=xcb" \
  "export QT_OPENGL=software" \
  "export LIBGL_ALWAYS_SOFTWARE=1" \
  "export QTWEBENGINE_DISABLE_GPU=1" \
  "export QTWEBENGINE_DISABLE_SANDBOX=1" \
  "export QTWEBENGINE_CHROMIUM_FLAGS=\"--disable-gpu --disable-dev-shm-usage --no-sandbox --single-process --no-zygote\"" \
  "export XDG_RUNTIME_DIR=\${XDG_RUNTIME_DIR:-/tmp/runtime-root}" \
  "mkdir -p \$XDG_RUNTIME_DIR && chmod 700 \$XDG_RUNTIME_DIR" \
  "source /opt/ros/'"${ROS_DISTRO}"'/setup.bash" \
  "source /ros2_ws/install/setup.bash" \
  "exec \"\$@\"" \
  > /entrypoint.sh && chmod +x /entrypoint.sh'

ENTRYPOINT ["/entrypoint.sh"]
CMD ["bash"]
